      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_ZABBIX_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    CASE t.priority\r\n        WHEN 1 THEN 'Information'\r\n        WHEN 2 THEN 'Warning'\r\n        WHEN 3 THEN 'Average'\r\n        WHEN 4 THEN 'High'\r\n        WHEN 5 THEN 'Disaster'\r\n    END AS severity,\r\n    COUNT(DISTINCT e.eventid) AS alarm_count\r\nFROM events e\r\nJOIN triggers t ON e.objectid = t.triggerid\r\nJOIN functions f ON e.objectid = f.triggerid\r\nJOIN items i ON f.itemid = i.itemid\r\nJOIN hosts h ON i.hostid = h.hostid\r\nWHERE e.source = 0\r\n  AND e.object = 0\r\n  AND e.value = 1\r\n  AND t.priority IN (1,2,3,4,5)\r\n  AND h.status = 0\r\n  AND (h.name = '$Host' OR h.host = '$Host')\r\n  AND e.clock BETWEEN $__unixEpochFrom() AND $__unixEpochTo()\r\nGROUP BY t.priority\r\nORDER BY t.priority;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Selected Host - Alarm Summary",
      "type": "table"
    },
