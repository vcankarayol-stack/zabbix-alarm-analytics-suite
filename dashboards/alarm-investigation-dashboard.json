      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_ZABBIX_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT ON (e.eventid)\r\n    CASE t.priority\r\n        WHEN 1 THEN 'Information'\r\n        WHEN 2 THEN 'Warning'\r\n        WHEN 3 THEN 'Average'\r\n        WHEN 4 THEN 'High'\r\n        WHEN 5 THEN 'Disaster'\r\n    END AS severity,\r\n\r\n    e.name AS problem_name,\r\n\r\n    to_char(\r\n        to_timestamp(e.clock),\r\n        'YYYY-MM-DD HH24:MI:SS'\r\n    ) AS problem_time,\r\n\r\n    ROUND(\r\n        (extract(epoch from now()) - e.clock) / 60.0,\r\n        0\r\n    ) AS open_minutes\r\n\r\nFROM events e\r\nJOIN triggers t ON e.objectid = t.triggerid\r\nJOIN functions f ON t.triggerid = f.triggerid\r\nJOIN items i ON f.itemid = i.itemid\r\nJOIN hosts h ON i.hostid = h.hostid\r\nLEFT JOIN event_recovery er ON er.eventid = e.eventid\r\n\r\nWHERE e.source = 0\r\n  AND e.object = 0\r\n  AND e.value = 1\r\n  AND er.r_eventid IS NULL\r\n  AND t.status = 0\r\n  AND h.status = 0\r\n  AND h.host = '$Host'\r\n\r\nORDER BY\r\n    e.eventid,\r\n    t.priority DESC,\r\n    open_minutes DESC;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
