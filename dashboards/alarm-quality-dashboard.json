          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    h.name AS host_name,\r\n    CASE t.priority\r\n        WHEN 3 THEN 'Average'\r\n        WHEN 4 THEN 'High'\r\n        WHEN 5 THEN 'Disaster'\r\n    END AS severity,\r\n    t.description AS trigger_name,\r\n    COUNT(DISTINCT e.eventid) AS alarm_count,\r\n    to_char(to_timestamp(MAX(e.clock)), 'YYYY-MM-DD HH24:MI:SS') AS last_alarm_time\r\nFROM events e\r\nJOIN triggers t ON e.objectid = t.triggerid\r\nJOIN functions f ON t.triggerid = f.triggerid\r\nJOIN items i ON f.itemid = i.itemid\r\nJOIN hosts h ON i.hostid = h.hostid\r\nWHERE e.source = 0\r\n  AND e.object = 0\r\n  AND e.value = 1\r\n  AND t.priority IN (3,4,5)\r\n  AND h.status = 0\r\n  AND t.status = 0\r\n  AND e.clock >= extract(epoch from date_trunc('month', now()))\r\nGROUP BY h.name, t.priority, t.description\r\nORDER BY alarm_count DESC\r\nLIMIT 20;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
