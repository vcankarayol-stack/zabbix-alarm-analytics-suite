        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "${DS_ZABBIX_POSTGRESQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\r\n    date_trunc('day', to_timestamp(e.clock)) AS time,\r\n    COUNT(DISTINCT e.eventid) AS alarm_count\r\nFROM events e\r\nJOIN triggers t ON e.objectid = t.triggerid\r\nJOIN functions f ON t.triggerid = f.triggerid\r\nJOIN items i ON f.itemid = i.itemid\r\nJOIN hosts h ON i.hostid = h.hostid\r\nWHERE e.source = 0\r\n  AND e.object = 0\r\n  AND e.value = 1\r\n  AND t.priority IN (2,3,4,5)\r\n  AND t.status = 0\r\n  AND h.status = 0\r\n  AND e.clock >= extract(epoch from date_trunc('month', now()))\r\nGROUP BY 1\r\nORDER BY 1;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Daily alarm trend",
      "type": "timeseries"
