          "rawSql": "SELECT\r\n    h.name AS host_name,\r\n    COUNT(DISTINCT e.eventid) AS alarm_count,\r\n    COUNT(DISTINCT t.triggerid) AS trigger_count,\r\n    to_char(to_timestamp(MAX(e.clock)), 'YYYY-MM-DD HH24:MI:SS') AS last_alarm_time\r\nFROM events e\r\nJOIN triggers t ON e.objectid = t.triggerid\r\nJOIN functions f ON t.triggerid = f.triggerid\r\nJOIN items i ON f.itemid = i.itemid\r\nJOIN hosts h ON i.hostid = h.hostid\r\nWHERE e.source = 0\r\n  AND e.object = 0\r\n  AND e.value = 1\r\n  AND t.priority IN (2,3,4,5)\r\n  AND h.status = 0\r\n  AND t.status = 0\r\n  AND e.clock >= extract(epoch from date_trunc('month', now()))\r\nGROUP BY h.name\r\nORDER BY alarm_count DESC\r\nLIMIT 20;",
